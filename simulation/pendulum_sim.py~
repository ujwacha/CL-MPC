"""
pendulum_sim.py  --  inverted pendulum sim
  UDP  port 9999 : TX [theta,omega,x,v] @ 50Hz  |  RX [a]
  WS   port 8765 : JSON state @ 50Hz  (for browser visualizer)

pip install websockets
"""
import socket, struct, threading, time, math, json

try:
    import websockets, asyncio
    HAS_WS = True
except ImportError:
    HAS_WS = False
    print("[WARN] pip install websockets  for browser viz")

# ── Physics (matches Lisp) ────────────────────────────────────────────────────
g, r, dt = -9.8, 0.1, 0.01
SEND_HZ   = 50
SEND_EVERY = max(1, int((1/dt) / SEND_HZ))

state   = [0.1, 0.0, 0.0, 0.0]
a       = 0.0
running = True
lk      = threading.Lock()

def pack_f(fs):  return struct.pack('<'+'f'*len(fs), *fs)
def unpack_f(d): n=len(d)//4; return list(struct.unpack('<'+'f'*n, d[:n*4]))

def step_sim(s, u):
    th, om, x, v = s
    ir2 = 1/(r*r)
    return [th + om*dt,
            om + dt*ir2*(g*math.sin(th) + u*math.cos(th)),
            x  + v*dt,
            v  + u*dt]

# ── WebSocket ─────────────────────────────────────────────────────────────────
ws_clients = set()
ws_loop    = None

def ws_broadcast(s):
    if not HAS_WS or ws_loop is None: return
    async def _b():
        dead = set()
        for ws in list(ws_clients):
            try:    await ws.send(s)
            except: dead.add(ws)
        ws_clients.difference_update(dead)
    asyncio.run_coroutine_threadsafe(_b(), ws_loop)

async def ws_handler(websocket):
    global a
    ws_clients.add(websocket)
    try:
        async for msg in websocket:
            try:
                d = json.loads(msg)
                if 'a' in d:
                    with lk: a = float(d['a'])
                if 'reset' in d:
                    vals = d['reset']
                    with lk: state[:] = [float(v) for v in vals]; a = 0.0
            except: pass
    except: pass
    finally: ws_clients.discard(websocket)

def _ws_thread():
    global ws_loop
    if not HAS_WS: return
    async def _run():
        global ws_loop
        ws_loop = asyncio.get_event_loop()
        async with websockets.serve(ws_handler, 'localhost', 8765):
            print("[WS ] ws://localhost:8765  -- open visualizer.html")
            await asyncio.Future()
    asyncio.run(_run())

# ── UDP ───────────────────────────────────────────────────────────────────────
udp_sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
udp_sock.bind(('localhost', 9999))
udp_sock.settimeout(0.05)
udp_client = None

def _udp_thread():
    global udp_client, a
    while running:
        try:
            data, addr = udp_sock.recvfrom(1024)
            udp_client = addr
            fs = unpack_f(data)
            if fs:
                with lk: a = fs[0]
                print(f"\n[UDP] a={fs[0]:.4f}\n> ", end='', flush=True)
        except socket.timeout: pass

def _sim_thread():
    global state
    n = 0
    while running:
        t0 = time.perf_counter()
        with lk:
            cur_a = a
            state = step_sim(state, cur_a)
            snap  = list(state)
        n += 1
        if n % SEND_EVERY == 0:
            if udp_client: udp_sock.sendto(pack_f(snap), udp_client)
            ws_broadcast(json.dumps({'theta':snap[0],'omega':snap[1],
                                     'x':snap[2],'v':snap[3],'a':cur_a,'t':n*dt}))
        sl = dt - (time.perf_counter()-t0)
        if sl > 0: time.sleep(sl)

for fn in (_ws_thread, _udp_thread, _sim_thread):
    threading.Thread(target=fn, daemon=True).start()

print("Inverted Pendulum Sim")
print("  UDP localhost:9999  TX [theta,omega,x,v] @ 50Hz  |  RX [a]")
print("  WS  ws://localhost:8765  -- open visualizer.html in browser")
print("\nCommands:  a <val>  |  reset [theta omega x v]  |  state  |  q\n")

while True:
    try:    cmd = input("> ").strip()
    except (EOFError, KeyboardInterrupt): running=False; print("\nBye."); break
    if   cmd == 'q':           running=False; break
    elif cmd == 'state':
        with lk: s=list(state)
        print(f"  th={s[0]:.4f} om={s[1]:.4f} x={s[2]:.4f} v={s[3]:.4f} a={a:.4f}")
    elif cmd.startswith('a '):
        try:
            with lk: a=float(cmd[2:])
            print(f"  a={a}")
        except: print("Bad value.")
    elif cmd == 'reset':
        with lk: state=[0.1,0,0,0]; a=0
        print("  Reset -> [0.1,0,0,0]")
    elif cmd.startswith('reset '):
        try:
            v=[float(x) for x in cmd[6:].split()]
            if len(v)==4:
                with lk: state=v
                print(f"  Reset -> {v}")
            else: print("  Need 4 values")
        except: print("Bad values.")
    else: print("Unknown.")

udp_sock.close()
